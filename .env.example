# Resend API key — get from https://resend.com/api-keys
RESEND_API_KEY=

# Email address that receives contact form submissions and newsletter signups
CONTACT_RECEIVER=

# Verified domain sender for visitor freebie delivery (e.g. Mohamed Dhia <hello@dhia-portfolio.me>)
DELIVERY_FROM=

# OpenRouter — powers the site chatbot (https://openrouter.ai/keys)
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-4o-mini

NEXT_PUBLIC_SITE_URL=https://dhia-portfolio.me
